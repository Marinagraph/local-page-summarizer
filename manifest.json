{
  "manifest_version": 2,
  "name": "Local Page Summarizer",
  "version": "0.3.23",
  "description": "Save the current page and summarize it with LM Studio running locally.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "downloads",
    "notifications",
    "<all_urls>",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "browser_action": {
    "default_title": "Save and summarize",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": "script-src 'self'; object-src 'self';",
  "browser_specific_settings": {
    "gecko": {
      "id": "local-page-summarizer@example.local",
      "data_collection_permissions": {
        "required": [
          "browsingActivity",
          "websiteContent"
        ]
      }
    }
  }
}
